{
  "name": "uni",
  "version": "2.1.4",
  "description": "My bibliographies all are in Cosense - Cross-browser extension (Chrome & Firefox compatible)",
  "scripts": {
    "build": "wxt build --browser chrome",
    "build:chrome": "wxt build --browser chrome",
    "build:firefox": "wxt build --browser firefox --mv3",
    "dev": "wxt --browser chrome",
    "dev:chrome": "wxt --browser chrome",
    "dev:firefox": "wxt --browser firefox --mv3",
    "watch": "wxt --browser chrome",
    "watch:chrome": "wxt --browser chrome",
    "watch:firefox": "wxt --browser firefox --mv3",
    "package:chrome": "wxt zip --browser chrome",
    "package:firefox": "wxt zip --browser firefox --mv3",
    "package:all": "npm run package:chrome && npm run package:firefox",
    "postinstall": "wxt prepare",
    "fmt": "prettier --write **/*.{ts,tsx,scss}",
    "test": "npm run test:small",
    "test:pr": "npm run test:small",
    "test:all": "npm run test:small && npm run test:large",
    "test:small": "NODE_OPTIONS=--experimental-vm-modules jest --selectProjects=small",
    "test:large": "playwright test",
    "test:large:japan": "playwright test --grep \"@japan\"",
    "test:large:global": "playwright test --grep \"@global\"",
    "test:extract-failed": "node scripts/extract-failed-tests.js",
    "test:extract-failed-from-ci": "node scripts/extract-from-ci.js",
    "test:failed-only": "if [ -f failed-tests-patterns.txt ]; then playwright test --grep \"$(cat failed-tests-patterns.txt | tr '\\n' '|' | sed 's/|$//')\"; else echo '❌ No failed tests patterns found. Run npm run test:extract-failed-from-ci or npm run test:extract-failed first.'; fi",
    "test:scraping-only": "playwright test src/__tests__/large/monitoring/scraping-logic.test.ts",
    "test:quick": "playwright test --grep \"FANZA Video|FANZA Doujin|Amazon.*English\"",
    "test:debug": "playwright test --debug --headed",
    "dep:check": "dependency-cruiser --config .dependency-cruiser.cjs src"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.2",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/chrome": "0.1.32",
    "@types/jest": "30.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/webextension-polyfill": "^0.12.3",
    "dependency-cruiser": "^17.4.3",
    "jest": "30.2.0",
    "jest-webextension-mock": "^4.0.0",
    "jsdom": "^27.0.0",
    "linkedom": "^0.18.12",
    "node-fetch": "^3.3.2",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "sass": "1.93.3",
    "tailwindcss": "^4.1.11",
    "ts-jest": "29.4.5",
    "typescript": "5.9.3",
    "webextension-polyfill": "^0.12.0",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "dayjs": "1.11.19",
    "ky": "1.14.2",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
