{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "jsx": "react",
    "lib": ["es2017", "dom", "dom.iterable"],
    "outDir": "dist/js",
    "rootDir": ".",
    "sourceMap": true,
    "strict": false,
    "target": "es6"
  },
  "exclude": [
    "playwright.config.ts",
    "webpack.*.js",
    "node_modules"
  ]
}
